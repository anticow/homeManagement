# HomeManagement — Docker Compose Environment Variables
#
# SETUP:
#   cp deploy/docker/.env.example deploy/docker/.env
#   Then fill in every value below. The .env file is gitignored — never commit it.
#
# GENERATING SECRETS (run each command once and paste the output):
#   PowerShell: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#   Bash:       openssl rand -base64 32
#
# For GitHub Actions, add each variable as a Repository Secret under:
#   Settings → Secrets and variables → Actions → New repository secret

# ── SQL Server ────────────────────────────────────────────────────────────────
# Strong password required by SQL Server (uppercase + lowercase + number + symbol, 8+ chars)
HM_SQL_SA_PASSWORD=

# ── JWT Signing Key ───────────────────────────────────────────────────────────
# Must be at least 32 bytes (44+ base64 chars). Generate with:
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
# Use 64 bytes for HS512 margin; HS256 minimum is 32 bytes.
HM_JWT_SIGNING_KEY=

# ── Audit HMAC Chain Key ──────────────────────────────────────────────────────
# 32-byte (256-bit) key for tamper-evident audit log chain (HMAC-SHA256).
# Generate: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# CRITICAL: rotating this key invalidates existing chain verification.
#           Back up old key before rotating; re-verify chain after.
HM_AUDIT_HMAC_KEY=

# ── Agent Gateway ─────────────────────────────────────────────────────────────
# Shared secret between broker and agent-gateway services.
# Generate: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
HM_AGENT_GATEWAY_API_KEY=

# ── Seq Log Server ────────────────────────────────────────────────────────────
# Admin password for the Seq web UI (http://localhost:5380).
# Set once on first run; Seq ignores it after the admin account is created.
HM_SEQ_ADMIN_PASSWORD=

# ── Bootstrap Admin Account ───────────────────────────────────────────────────
# One-time admin seeding. Set HM_BOOTSTRAP_ADMIN_ENABLED=false after first login.
# IMPORTANT: disable immediately after seeding — see ansible role homemanagement/defaults/main.yml
HM_BOOTSTRAP_ADMIN_ENABLED=true
HM_BOOTSTRAP_ADMIN_USERNAME=admin
HM_BOOTSTRAP_ADMIN_PASSWORD=
