<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HomeManagement.Gui.ViewModels"
             x:Class="HomeManagement.Gui.Views.CredentialsView"
             x:DataType="vm:CredentialsViewModel">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Credentials" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
        </StackPanel>

        <ListBox ItemsSource="{Binding Credentials}" Margin="0,8,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="4">
                        <Button DockPanel.Dock="Right" Content="Remove"
                                Command="{Binding $parent[UserControl].((vm:CredentialsViewModel)DataContext).RemoveCommand}"
                                CommandParameter="{Binding Id}" Padding="8,4" FontSize="11" />
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding Name}" Width="200" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Username}" Width="150" Foreground="#888" />
                            <TextBlock Text="{Binding Type}" Foreground="#888" />
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
