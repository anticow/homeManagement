<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HomeManagement.Gui.ViewModels"
             x:Class="HomeManagement.Gui.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,*" Margin="0,0,0,16">
            <!-- Summary cards -->
            <Border Grid.Column="0" Background="#2D2D3D" CornerRadius="8" Padding="16" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="Machines" Foreground="#888" FontSize="12" />
                    <TextBlock Text="{Binding MachineCount}" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#2D2D3D" CornerRadius="8" Padding="16" Margin="4,0,4,8">
                <StackPanel>
                    <TextBlock Text="Connected Agents" Foreground="#888" FontSize="12" />
                    <TextBlock Text="{Binding ConnectedAgents.Count}" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#2D2D3D" CornerRadius="8" Padding="16" Margin="4,0,4,8">
                <StackPanel>
                    <TextBlock Text="Recent Jobs" Foreground="#888" FontSize="12" />
                    <TextBlock Text="{Binding RecentJobs.Count}" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="#2D2D3D" CornerRadius="8" Padding="16" Margin="8,0,0,8">
                <StackPanel>
                    <TextBlock Text="Health" Foreground="#888" FontSize="12" />
                    <TextBlock Text="{Binding HealthReport.OverallStatus}" FontSize="28" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <!-- Recent jobs list -->
            <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#2D2D3D" CornerRadius="8" Padding="16" Margin="0,8,4,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Recent Jobs" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding RecentJobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4">
                                    <TextBlock Text="{Binding Name}" Width="200" />
                                    <TextBlock Text="{Binding State}" Width="100" />
                                    <TextBlock Text="{Binding CreatedUtc}" Foreground="#888" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Connected agents list -->
            <Border Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Background="#2D2D3D" CornerRadius="8" Padding="16" Margin="4,8,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Connected Agents" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding ConnectedAgents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E2E" CornerRadius="4" Padding="12" Margin="0,4">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold" FontSize="14" />
                                            <TextBlock Text="{Binding AgentVersion}" Foreground="#888" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <TextBlock Foreground="#888" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="ID: {0}">
                                                        <Binding Path="AgentId" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Foreground="#888" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Uptime: {0}">
                                                        <Binding Path="Uptime" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <Button Content="Refresh" Command="{Binding RefreshCommand}" HorizontalAlignment="Left" />
    </DockPanel>
</UserControl>
