<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HomeManagement.Gui.ViewModels"
             x:Class="HomeManagement.Gui.Views.JobDetailView"
             x:DataType="vm:JobDetailViewModel">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Job Detail" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button Content="Cancel Job" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>

        <ScrollViewer>
            <StackPanel Spacing="16">
                <Border Background="#2D2D3D" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding Status.Name}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Status.State, StringFormat='State: {0}'}" Foreground="#888" />
                        <TextBlock Text="{Binding Status.Progress, StringFormat='Progress: {0}%'}" Foreground="#888" />
                    </StackPanel>
                </Border>

                <TextBlock Text="Machine Results" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding MachineResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,2">
                                <TextBlock Text="{Binding Hostname}" Width="200" />
                                <TextBlock Text="{Binding Outcome}" Width="100" />
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
