<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HomeManagement.Gui.ViewModels"
             x:Class="HomeManagement.Gui.Views.ServicesView"
             x:DataType="vm:ServicesViewModel">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Services" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Machine:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Machines}"
                          SelectedItem="{Binding SelectedMachine}"
                          Width="300" PlaceholderText="Select a machine...">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Hostname}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            </StackPanel>
        </StackPanel>

        <ListBox ItemsSource="{Binding Services}" Margin="0,8,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="4">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                            <Button Content="Start" Command="{Binding $parent[UserControl].((vm:ServicesViewModel)DataContext).StartServiceCommand}"
                                    CommandParameter="{Binding}" Padding="8,4" FontSize="11" />
                            <Button Content="Stop" Command="{Binding $parent[UserControl].((vm:ServicesViewModel)DataContext).StopServiceCommand}"
                                    CommandParameter="{Binding}" Padding="8,4" FontSize="11" />
                            <Button Content="Restart" Command="{Binding $parent[UserControl].((vm:ServicesViewModel)DataContext).RestartServiceCommand}"
                                    CommandParameter="{Binding}" Padding="8,4" FontSize="11" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding Name}" Width="250" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding State}" Width="100" />
                            <TextBlock Text="{Binding DisplayName}" Foreground="#888" />
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
