<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HomeManagement.Gui.ViewModels"
             x:Class="HomeManagement.Gui.Views.PatchingView"
             x:DataType="vm:PatchingViewModel">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,16">
            <!-- Title row with source badge -->
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Patching" FontSize="24" FontWeight="Bold" />
                <Border Background="#1976d2" CornerRadius="4" Padding="6,2">
                    <TextBlock Text="{Binding SourceLabel}" Foreground="White"
                               FontSize="11" FontWeight="Bold" LetterSpacing="0.5" />
                </Border>
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="#4CAF50"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Machine selector + action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Machine:" VerticalAlignment="Center" />
                <ComboBox ItemsSource="{Binding Machines}"
                          SelectedItem="{Binding SelectedMachine}"
                          Width="300" PlaceholderText="Select a machine...">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Hostname}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="{Binding ScanButtonLabel}"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding IsScanning, Converter={x:Static BoolConverters.Not}}" />
                <Button Content="Apply Patches" Command="{Binding ApplyCommand}" />
            </StackPanel>
        </StackPanel>

        <Grid RowDefinitions="*" Margin="0,8,0,0">
            <DockPanel Grid.Row="0">
                <!-- Patch count in header -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                    <TextBlock Text="Detected Patches" FontWeight="SemiBold" />
                    <Border Background="#e3f2fd" CornerRadius="10" Padding="6,1"
                            IsVisible="{Binding PatchCount, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="{Binding PatchCount}" FontSize="11" Foreground="#1976d2" />
                    </Border>
                </StackPanel>
                <ListBox ItemsSource="{Binding DetectedPatches}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="4">
                                <TextBlock Text="{Binding PatchId}" Width="200" />
                                <TextBlock Text="{Binding Severity}" Width="100" />
                                <TextBlock Text="{Binding Title}" Foreground="#888" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
