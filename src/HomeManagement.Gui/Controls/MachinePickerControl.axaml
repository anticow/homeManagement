<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HomeManagement.Gui.Controls.MachinePickerControl">
    <DockPanel>
        <TextBox DockPanel.Dock="Top" Watermark="Filter machines…"
                 Text="{Binding FilterText, Mode=TwoWay}"
                 Margin="0,0,0,4" />
        <ListBox ItemsSource="{Binding FilteredMachines}"
                 SelectedItem="{Binding SelectedMachine}"
                 SelectionMode="Multiple"
                 MaxHeight="250">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding IpAddress}" Foreground="#888" FontSize="12" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
