{
  "Auth": {
    "JwtSigningKey": "CHANGE-ME-generate-a-32-byte-random-key",
    "Issuer": "homemanagement",
    "Audience": "homemanagement-api"
  },
  "ReverseProxy": {
    "Routes": {
      "broker-api": {
        "ClusterId": "broker",
        "Match": {
          "Path": "/api/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "auth-api": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/auth/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/auth" }
        ]
      }
    },
    "Clusters": {
      "broker": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:8082"
          }
        }
      },
      "auth": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:8083"
          }
        }
      }
    }
  },
  "Seq": {
    "Url": "http://localhost:5341"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information",
        "System.Net.Http": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
