@page "/credentials"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HomeManagement.Abstractions.Models
@inject HomeManagement.Web.Services.IBrokerApi BrokerApi
@inject NavigationManager Navigation

<h1>Credentials</h1>

@if (_loading)
{
    <p>Loading credentials...</p>
}
else if (_errorMessage is not null)
{
    <p>@_errorMessage</p>
}
else if (_credentials is not null)
{
    @if (_credentials.Count == 0)
    {
        <p>No credentials stored.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Label</th>
                    <th>Type</th>
                    <th>Username</th>
                    <th>Created</th>
                    <th>Last Used</th>
                    <th>Last Rotated</th>
                    <th>Machines</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cred in _credentials)
                {
                    <tr>
                        <td>@cred.Label</td>
                        <td>@cred.Type</td>
                        <td>@cred.Username</td>
                        <td>@cred.CreatedUtc.ToString("g")</td>
                        <td>@(cred.LastUsedUtc?.ToString("g") ?? "—")</td>
                        <td>@(cred.LastRotatedUtc?.ToString("g") ?? "—")</td>
                        <td>@cred.AssociatedMachineIds.Length</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private bool _loading = true;
    private IReadOnlyList<CredentialEntry>? _credentials;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _credentials = await BrokerApi.GetCredentialsAsync();
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load credentials: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
