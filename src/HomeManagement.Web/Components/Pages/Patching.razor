@page "/patching"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using HomeManagement.Abstractions.Models
@using HomeManagement.Web.Services
@inject IBrokerApi BrokerApi
@inject NavigationManager Navigation

<div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
    <h1 style="margin:0;">Patching</h1>
    <span style="background:#1976d2; color:white; border-radius:4px; padding:2px 10px; font-size:0.75rem; font-weight:bold; letter-spacing:.05em;">Action1 RMM</span>
</div>

<p>Select a machine to scan for available patches or review deployment history.</p>

@if (_loading)
{
    <p>Loading machines...</p>
}
else if (_machines is not null)
{
    <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
        <label for="machine-select">Machine:</label>
        <select id="machine-select" @onchange="OnMachineSelected">
            <option value="">-- Select a machine --</option>
            @foreach (var m in _machines.Items)
            {
                <option value="@m.Id">@m.Hostname</option>
            }
        </select>
        @if (_selectedMachineId is not null)
        {
            <button @onclick="ScanForPatchesAsync" disabled="@_scanning">
                @(_scanning ? "Scanning…" : "Scan for Patches")
            </button>
        }
    </div>

    @if (_selectedMachineId is not null)
    {
        @if (_detectedPatches is not null)
        {
            <h2>Detected Patches (@_detectedPatches.Count)</h2>
            @if (_detectedPatches.Count > 0)
            {
                <table>
                    <thead>
                        <tr>
                            <th>Patch ID</th>
                            <th>Title</th>
                            <th>Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in _detectedPatches)
                        {
                            <tr>
                                <td>@p.PatchId</td>
                                <td>@p.Title</td>
                                <td>@p.Severity</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>No patches detected — this machine is up to date.</p>
            }
        }

        <h2>Deployment History</h2>
        @if (_historyLoading)
        {
            <p>Loading deployment history...</p>
        }
        else if (_history is not null && _history.Count > 0)
        {
            <table>
                <thead>
                    <tr>
                        <th>Patch</th>
                        <th>Title</th>
                        <th>State</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _history)
                    {
                        <tr>
                            <td>@entry.PatchId</td>
                            <td>@entry.Title</td>
                            <td>@entry.State</td>
                            <td>@entry.TimestampUtc.ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>No deployment history found for this machine.</p>
        }
    }
}
else if (_errorMessage is not null)
{
    <p>@_errorMessage</p>
}

@code {
    private bool _loading = true;
    private bool _scanning;
    private bool _historyLoading;
    private PagedResult<Machine>? _machines;
    private Guid? _selectedMachineId;
    private IReadOnlyList<PatchHistoryEntry>? _history;
    private IReadOnlyList<PatchInfo>? _detectedPatches;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _machines = await BrokerApi.GetMachinesAsync();
        }
        catch (UnauthorizedAccessException)
        {
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load machines: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnMachineSelected(ChangeEventArgs e)
    {
        _detectedPatches = null;
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedMachineId = id;
            _historyLoading = true;
            try
            {
                _history = await BrokerApi.GetPatchHistoryAsync(id);
            }
            catch (Exception ex)
            {
                _errorMessage = $"Unable to load deployment history: {ex.Message}";
            }
            finally
            {
                _historyLoading = false;
            }
        }
    }

    private async Task ScanForPatchesAsync()
    {
        if (_selectedMachineId is null) return;
        _scanning = true;
        _errorMessage = null;
        try
        {
            _detectedPatches = await BrokerApi.ScanPatchesAsync(new PatchScanRequest(_selectedMachineId.Value));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Scan failed: {ex.Message}";
        }
        finally
        {
            _scanning = false;
        }
    }
}
